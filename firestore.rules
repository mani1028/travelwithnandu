rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /artifacts/travel-nandu-v1 {
      // Allow drivers to read/write their own profile (ID can be UID or Phone)
      match /drivers/{identifier} {
        allow read, write: if isSignedIn();
      }

      // Allow drivers to sync their live trip document
      match /trips/{driverId} {
        allow read, write: if isSignedIn();
      }

      // Allow drivers to see available jobs and their assigned jobs
      match /public/data/bookings/{bookingId} {
        allow read: if isSignedIn();
        allow update: if isSignedIn() && 
          (resource.data.status == 'pending' || resource.data.driverId == request.auth.uid);
      }

      // Allow drivers to manage their own wallet and expenses
      match /drivers/{driverId}/expenses/{expenseId} {
        allow read, write: if isSignedIn();
      }
      match /drivers/{driverId}/wallet_txns/{txnId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }
  }
}
